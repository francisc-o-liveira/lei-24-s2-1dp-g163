@startuml
'skinparam monochrome true
skinparam packageStyle rectangle
skinparam shadowing false
skinparam linetype polyline
'skinparam linetype orto

skinparam classAttributeIconSize 0

'left to right direction

class ApplicationSession{
    + static getInstance()
    + getCurrentSession()
}

class UserSession{
}

class HRM {
}

class Collaborator {
    - name
    - date of birthday
    - admission data
    - address street zipcode
    - address city, email
    - phone number
    - docType
    - docIDNumber
    - jobCategory

    + Collaborator(name, date of birthday, admission data, address street,\n zipcode, address city, email, phone number, docType,\n docIDNumber, jobCategory)
}

class JobCategory {
    - String name
    + JobCategory(name)
}

class CollaboratorRepository {
    - List <Collaborator> collaboratorsNotActivate
    - List <Collaborator> collaboratorsActivate
    - List <DocType>
    + registerCollaborator(name, date of birthday, admission data, address street, zipcode,\n address city, email, phone number, docType,\n docIDNumber, jobCategory)
    + isValidCollaborator(collaborator)
    + saveCollaborator(collaborator, this.collaboratorsNotActivate)
    + validateDocType(docType,docTypeNumber);
    + addCollaborator(collaborator)
}

class DocType{
    -enum type
    +DocType(type)
}

class JobCategoryRepository {
    - List <JobCategory>
    + getJobCategoryList()
}


class Repositories {
    - Repositories()
    + getInstance() : Repositories
    + getJobCategoryRepository()
    + getCollaboratorRepository()
}

class RegisterCollaboratorController {
    - CollaboratorRepository collaboratorRepository
    - JobCategoryRepository jobCategoryRepository
    + RegisterCollaboratorController()
    + getJobCategoriesList()
    + registerCollaborator(name, date of birthday, admission data,\n address street, zipcode, address city, email, phone number, docType,\n docIDNumber, jobCategory)
    + getDocTypeList()
    - getHRMFromSession()
}

note right of RegisterCollaboratorController
    - userEmail is obtained
    from the user session
    - jobCategory
    is achieved with job category repository
end note

note bottom of JobCategoryRepository
    - used for displaying
    the job category list
end note

class RegisterCollaboratorUI {
}

Repositories -> Repositories : instance
ApplicationSession -> ApplicationSession : instance

RegisterCollaboratorUI .> RegisterCollaboratorController

RegisterCollaboratorController .> Repositories : repositories

Repositories -> "1" JobCategoryRepository

RegisterCollaboratorController ..> CollaboratorRepository : CollaboratorRepository
RegisterCollaboratorController ..> JobCategoryRepository : JobCategoryRepository
RegisterCollaboratorController --> DocType
Repositories --> "1" CollaboratorRepository

ApplicationSession --> "1" UserSession : userSession
RegisterCollaboratorController ..> "1" CollaboratorRepository : collaboratorRepository
RegisterCollaboratorController ..> ApplicationSession
RegisterCollaboratorController ..> UserSession
Collaborator "*" --> "1" JobCategory : jobCategory
JobCategoryRepository "1" --> "*" JobCategory : jobCategory's
CollaboratorRepository "1" --> "*" Collaborator : collaborators
CollaboratorRepository "1" --> "3" DocType : docTypes
Collaborator --> Employee : createdBy

CollaboratorRepository --> "*" HRM : employs
JobCategoryRepository --> "*" HRM : employs


@enduml