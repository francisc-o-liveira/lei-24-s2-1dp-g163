@startuml
skinparam monochrome true
skinparam packageStyle rectangle
skinparam shadowing false

participant "collaboratorRepository\n:CollaboratorRepository" as ORG
participant "collaborator\n:Collaborator" as collaborator

autonumber 16
-> ORG: registerCollaborator(reference, description,\ninformalDescription, technicalDescription,\nduration, cost, taskCategory, employee )

autonumber 16.1
activate ORG
    group Create Task

        ORG -> collaborator**: Collaborator(name, date of birthday, admission data,\n address street, zipcode, address city, email, phone number, docType,\n docIDNumber, jobCategory)
        ORG -> ORG: addCollaborator (collaborator)

        activate ORG
            ORG -> ORG: validateCollaborator(collaborator)
            activate ORG
                ORG --> ORG
            deactivate ORG

            ORG --> ORG
        deactivate ORG
    end

    autonumber 17
    <-- ORG : true / collaboratorList
deactivate ORG


@enduml