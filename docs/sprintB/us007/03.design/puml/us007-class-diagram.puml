@startuml
'skinparam monochrome true
skinparam packageStyle rectangle
skinparam shadowing false
skinparam linetype polyline
'skinparam linetype orto

skinparam classAttributeIconSize 0

'left to right direction

class ApplicationSession {
    + static getInstance()
    + getCurrentSession()
}

class UserSession {
}

class HRManager {
}

class Employee {
    - name: String
    - employeeID: String
    - skills: List<Skill>
}

class Skill {
    - name: String
    - description: String
}

class EmployeeRepository {
    - List<Employee>
    + checkHRManagerAuthorization(employeeID): boolean
    + fetchEmployeeIDs(): List<String>
    + fetchEmployeeDetails(employeeID): Employee
    + assignSkillToEmployee(employeeID, skill): boolean
}

class SkillRepository {
    - List<Skill>
    + getAllSkills(): List<Skill>
}

class Repositories {
    - instance: Repositories
    + getInstance(): Repositories
    + getEmployeeRepository(): EmployeeRepository
    + getSkillRepository(): SkillRepository
}

class AssignSkillsController {
    + AssignSkillsController(employeeRepository, skillRepository)
    + assignSkills(employeeID, skills)
    + checkAuthorization()
    + getEmployeeIDList()
    + getEmployeeDetails(ID)
    + filterAssignedSkills(employeeSkills, allSkills)
}

note right of AssignSkillsController
    - Authorization is checked against
    the HRManager roles in the system
    - Employee and Skill information
    are obtained from their respective repositories
end note

class AssignSkillsUI {
}

Repositories --> Repositories : instance
ApplicationSession --> ApplicationSession : instance

AssignSkillsUI .> AssignSkillsController

AssignSkillsController .> Repositories : uses >>Singleton<<

Repositories --> "1" EmployeeRepository
Repositories --> "1" SkillRepository

AssignSkillsController ..> Skill
AssignSkillsController ..> EmployeeRepository : uses
AssignSkillsController ..> SkillRepository : uses

EmployeeRepository "1" --> "*" Employee : employees
SkillRepository "1" --> "*" Skill : skills

Employee "1" -right- "*" Skill : "has"

note bottom of EmployeeRepository
    - Responsible for all data handling
    concerning employees, including skill assignment
end note

note bottom of SkillRepository
    - Manages the retrieval and
    storage of skill information
end note

ApplicationSession --> "1" UserSession : userSession

AssignSkillsController ..> UserSession : userSession
HRManager -down-> AssignSkillsUI : interacts with

@enduml
