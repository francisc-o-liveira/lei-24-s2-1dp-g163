@startuml
skinparam monochrome true
skinparam packageStyle rectangle
skinparam shadowing false

'left to right direction

skinparam classAttributeIconSize 0

hide circle
hide methods

'title Domain Model

'class Platform {
'  -description
'}

class HRM {
    name
    email
    password
}

class Skill {
    skillName
}

class Collaborator{
job
task
name
birthdate
admissionDate
address
mobileNumber
email
docType
docNumber
}

class Team {
    skillSet
    sizeTeam
}


HRM "1" - "0..*" Team: generate >
Team "1" - "0..*" Skill: have >
Team "1" - "1..*" Collaborator: have>
Collaborator "1" -- "0..*" Skill: have>

@enduml