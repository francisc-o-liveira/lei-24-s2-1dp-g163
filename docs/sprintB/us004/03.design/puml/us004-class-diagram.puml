@startuml
'skinparam monochrome true
skinparam packageStyle rectangle
skinparam shadowing false
skinparam linetype polyline
'skinparam linetype orto

skinparam classAttributeIconSize 0

    
class AssignSkillsUI {
}

class AssignSkillsController {
    - CollaboratorRepository collaboratorRepository
    - SkillRepository skillRepository
    + AssignSkillsController()
    + getCollaboratorIDList()
    + getCollaboratorDetails(ID)
    + getAllSkills()
    + filterAssignedSkills(Collaborator Skills, All Skills)
    + assignSkills(CollaboratorID, Skill(s) name(s))
}

class Repositories {
    - Repositories()
    + getInstance() : Repositories
    + getCollaboratorRepository()
    + getSkillRepository()
}

class CollaboratorRepository {
    - List<Collaborator> collaborators
    + checkHRManager(userEmail)
    + fetchCollaboratorIDs()
    + fetchCollaboratorDetails(CollaboratorID)
    + assignSkillToCollaborator(CollaboratorID, Skill(s) Name(s))
}

class SkillRepository {
    - List<Skill> skills
    + getAllSkills()
}

class HRM {
    + isHRM(userEmail: String) : boolean
}

class Collaborator {
    - String name
    - List<Skill> skills
    + assignSkill(Skill Name)
}


Repositories ->  Repositories : instance
AssignSkillsUI "1" -> "1" AssignSkillsController: initializes

AssignSkillsController "1" -> "1" Repositories : repositories
Repositories "1" -> "1" CollaboratorRepository 
Repositories "1" -> "1" SkillRepository 

AssignSkillsController "1" -down-> "1" CollaboratorRepository : collaboratorRepository
AssignSkillsController "1" -down-> "1" SkillRepository : skillRepository

CollaboratorRepository "1" o-- "*" Collaborator 
CollaboratorRepository "1" o-- "*" HRM 

@enduml
