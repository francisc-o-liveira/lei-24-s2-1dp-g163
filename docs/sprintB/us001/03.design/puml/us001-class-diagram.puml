@startuml
'skinparam monochrome true
skinparam packageStyle rectangle
skinparam shadowing false
skinparam linetype polyline
'skinparam linetype orto

skinparam classAttributeIconSize 0

'left to right direction

class ApplicationSession{
    + static getInstance()
    + getCurrentSession()
}

class UserSession{
}

class HRM {
}

class Skill {
    - String name
    + Skill(name)
}



class skillRepository {
    - List <Skill>
    + getSkillList()
}


class Repositories {
    - Repositories()
    + getInstance() : repositories
    + getSkillRepository()

}

class RegisterSkillController{
    + registerSkill(skillRepository)
    + getJSkillList()
    + getSkillRepository
}

note right of RegisterSkillController
    - skillName
    is achieved with skill repository
end note

note bottom of skillRepository
    - used for displaying
    the skill list
end note

class RegisterSkillUI {
}

Repositories -> Repositories : instance
ApplicationSession -> ApplicationSession : instance

RegisterSkillUI .> RegisterSkillController

RegisterSkillController .> Repositories : repositories

Repositories -> "1" skillRepository
RegisterSkillController ..> Skill
RegisterSkillController ..> skillRepository : skillRepository


ApplicationSession --> "1" UserSession : userSession

RegisterSkillController ..> ApplicationSession
RegisterSkillController ..> UserSession

skillRepository "1" --> "*" Skill : Skills

Skill--> HRM : createdBy

skillRepository --> "*" HRM : employs

@enduml