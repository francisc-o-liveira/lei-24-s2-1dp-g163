@startuml
'skinparam monochrome true
skinparam packageStyle rectangle
skinparam shadowing false
skinparam linetype polyline
'skinparam linetype orto

skinparam classAttributeIconSize 0

'left to right direction

class ApplicationSession{
    + static getInstance()
    + getCurrentSession()
}

class UserSession{
}

class HRM {
}

class JobCategory {
    - String name
    + JobCategory(name)
}



class JobCategoryRepository {
    - List <JobCategory>
    + getJobCategoryList()
}


class Repositories {
    - Repositories()
    + getInstance() : Repositories
    + getJobCategoryRepository()
    + getCollaboratorRepository()
}

class CreateJobCategoryController{
    + RegisterCollaboratorController(collaboratorRepository, jobCategoryRepository)
    + getJobCategoriesList()
    + registerCollaborator(name, date of birthday, admission data,\n address street, zipcode, address city, email, phone number, docType,\n docIDNumber, jobCategory)
    - getEmployeeFromSession()
}

note right of CreateJobCategoryController
    - userEmail is obtained
    from the user session
    - jobCategory
    is achieved with job category repository
end note

note bottom of JobCategoryRepository
    - used for displaying
    the job category list
end note

class CreateJobCategoryUI {
}

Repositories -> Repositories : instance
ApplicationSession -> ApplicationSession : instance

CreateJobCategoryUI .> CreateJobCategoryController

CreateJobCategoryController .> Repositories : repositories

Repositories -> "1" JobCategoryRepository

CreateJobCategoryController ..> JobCategory
CreateJobCategoryController ..> CollaboratorRepository : CollaboratorRepository
CreateJobCategoryController ..> JobCategoryRepository : JobCategoryRepository


ApplicationSession --> "1" UserSession : userSession

CreateJobCategoryController ..> ApplicationSession
CreateJobCategoryController ..> UserSession

JobCategoryRepository "1" --> "*" JobCategory : jobCategory's

JobCategory --> HRM : createdBy

JobCategoryRepository --> "*" HRM : employs

@enduml