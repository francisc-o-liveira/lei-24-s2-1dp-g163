@startuml
skinparam monochrome true
skinparam packageStyle rectangle
skinparam shadowing false

participant "organization\n:Organization" as ORG
participant "collaborator\n:Collaborator" as collaborator

autonumber 16
-> ORG: registerCollaborator(reference, description,\ninformalDescription, technicalDescription,\nduration, cost, taskCategory, employee )

autonumber 16.1
activate ORG
    group Create Task

        ORG -> collaborator**: register(reference, description,\ninformalDescription, technicalDescription,\nduration, cost, taskCategory, employee)
        ORG -> ORG: addCollaborator (collaborator)

        activate ORG
            ORG -> ORG: validateCollaborator(collaborator)
            activate ORG
                ORG --> ORG
            deactivate ORG

            ORG --> ORG
        deactivate ORG
    end

    autonumber 17
    <-- ORG : collaborator
deactivate ORG


@enduml