@startuml
skinparam monochrome true
skinparam packageStyle rectangle
skinparam shadowing false

autonumber

'hide footbox
actor "HRM" as ADM
participant ":RegisterCollaboratorUI" as UI
participant ":RegisterCollaboratorController" as CTRL
participant "organization\n:Organization" as ORG

activate ADM

    ADM -> UI : asks to register a new Collaborator

    activate UI

        UI -> CTRL** : register
        UI -> CTRL : getJobCategories()
        ref over CTRL
            Get Job Category List

        end ref

        activate CTRL

            CTRL --> UI : jobCategoryList
        deactivate CTRL

        UI --> ADM : shows job category list and asks to sleect one
    deactivate UI

    ADM -> UI : selects a job category
    activate UI

        UI --> ADM : requests data
    deactivate UI

    ADM -> UI : types requested data (job name)
    activate UI

        UI --> ADM : shows selected category and requested data
    deactivate UI

    ADM -> UI : submits data
    activate UI

        UI -> CTRL : registerCollaborator(reference, description, informalDescription,\ntechnicalDescription,duration, cost, taskCategoryDescription)
        activate CTRL

            CTRL -> CTRL : getJobCategoryByDescription(taskCategoryDescription)
            activate CTRL

                ref over CTRL
                    Get Job Category Object

                end ref

                CTRL --> CTRL : jobCategory
            deactivate CTRL


            CTRL -> ORG: registerCollaborator(reference, description, informalDescription,\ntechnicalDescription, duration, cost, taskCategory, employee)
            activate ORG

                ref over ORG
                    Register Collaborator

                end

                ORG --> CTRL : collaborator
            deactivate ORG

            CTRL --> UI: collaborator
            deactivate CTRL
            UI --> ADM: displays operation success
    deactivate UI

deactivate ADM

@enduml