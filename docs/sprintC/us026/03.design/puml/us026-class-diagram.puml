@startuml
'skinparam monochrome true
skinparam packageStyle rectangle
skinparam shadowing false
skinparam linetype polyline
'skinparam linetype orto

skinparam classAttributeIconSize 0

'left to right direction

package "Domain" {
class Entry {
    - List<Vehicle>
    + Entry()
    + setNewVehicle()
    + removeVehicle()
}

class Task{
}
class EntryRepository {
    - List <Entry> : agenda

    + getAgendaList()
    + assignVehicleToEntry(vehicle,entry)
    + filterVehiclesNotUseInTime(vehicleList,entryDto)
}


note bottom of EntryRepository
    - used for displaying
    the to do list
end note

class VehicleRepository{
    - List<Vehicle>

    + getVehicleList()
}

class Vehicle {
    - String email
}


class Repositories {
    - Repositories()
    + getInstance() : Repositories
    + getEntryRepository()
    + getVehicleRepository()
}

class EntryMapper{
    - List<EntryDto>
    + toModel()
    + toDto()
}

class EntryDto{
}

class VehicleMapper{
    - List<VehicleDto>
    + toModel()
    + toDto()
}

class VehicleDto{
}

}



class CollaboratorUser {
}


package "Controller"{

class AssignedVehicleToEntryController {
    - EntryRepository entryRepository
    - VehicleRepository vehicleRepository
    + AssignedVehicleToEntryController()
    + getEntrysInAgenda()
    + getVehicleList()
    - getCollaboratorFromSession()
}

note left of AssignedVehicleToEntryController
    - entry is achieved with entry repository
end note


}



package "UI"{

class AssignedVehicleToEntryUI {
}

}
Repositories -> Repositories : instance


AssignedVehicleToEntryUI .> AssignedVehicleToEntryController

AssignedVehicleToEntryController .> Repositories : repositories
Repositories "1" --> "1" EntryRepository
Repositories "1" --> "1" VehicleRepository

AssignedVehicleToEntryController ..> EntryRepository : EntryRepository
AssignedVehicleToEntryController ..> EntryMapper : EntryMapper
AssignedVehicleToEntryController ..> VehicleMapper : VehicleMapper

EntryMapper "1" --> "*" EntryDto

VehicleRepository "1" --> "*" Vehicle : vehicles

EntryRepository "1" --> "*" Entry : entry's
EntryRepository --> "*" CollaboratorUser : employs
EntryRepository ..> EntryMapper
VehicleRepository ..> VehicleMapper

VehicleMapper "1" --> "*" VehicleDto

Entry --> "*" CollaboratorUser : employs
Task "1" -> "1" Entry : extends


@enduml