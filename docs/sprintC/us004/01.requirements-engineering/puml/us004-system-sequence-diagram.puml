@startuml
skinparam monochrome true
skinparam packageStyle rectangle
skinparam shadowing false

autonumber

actor "HRM" as HRManager
participant ":System" as System

activate HRManager

HRManager -> System : Asks to assign skills to a specific collaborator
activate System

System --> HRManager :  Displays collaborator list
deactivate System

HRManager -> System : Selects collaborator
activate System

System --> HRManager : Displays Available Skills to Assign
deactivate System

HRManager -> System : Selects Skill and Submits
activate System

System --> HRManager : Displays operation success message

deactivate System
@enduml
