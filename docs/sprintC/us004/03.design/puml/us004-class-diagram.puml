@startuml
skinparam packageStyle rectangle
skinparam shadowing false
skinparam linetype polyline
skinparam classAttributeIconSize 0

class SkillRepository {
    - skillList : List<Skill>
    + addSkill(skill : Skill) : void
    + getAllSkillNames() : List<String>
    + findSkillByName(name : String) : Skill
}

class AssignSkillsUI {
}

class AssignSkillsController {
    - repositories : Repositories
    + AssignSkillsController()
    + getDataNeededToAssignSkills() : List<String>
    + getAvailableSkillsList(collaboratorName : String) : List<String>
    + assignSkills(collaboratorName : String, skillName : String) : boolean
    + getCollaboratorSkills(collaboratorName : String) : List<String>
}

class CollaboratorRepository {
    - collaboratorList : List<Collaborator>
    + addCollaborator(collaborator : Collaborator) : void
    + getCollaboratorNames() : List<String>
    + findCollaboratorByName(name : String) : Collaborator
    + assignSkillToCollaborator(collaboratorName : String, skillName : String) : boolean
    + getCollaboratorSkills(collaboratorName : String) : List<String>
    + getAvailableSkillsList(collaboratorName : String, allSkills : List<String>) : List<String>
}

class Collaborator {
    - skills : Skills
    + getSkills() : List<String>
    + assignSkill(skillName : String) : void
    + filterAssignedSkills(allSkills : List<String>) : List<String>
}

class Skills {
    - skillList : List<Skill>
    + addSkill(skill : Skill) : void
    + getSkills() : List<Skill>
    + filterAssignedSkills(allSkills : List<Skill>) : List<String>
    + getSkillNames() : List<String>
}

class Skill {
    - name : String
    + getName() : String
}

class Repositories {
    - static instance : Repositories
    - collaboratorRepository : CollaboratorRepository
    - skillRepository : SkillRepository
    + getInstance() : Repositories
    + getCollaboratorRepository() : CollaboratorRepository
    + getSkillRepository() : SkillRepository
    - Repositories()
}

AssignSkillsUI ..> AssignSkillsController
AssignSkillsController ..> Repositories : repositories
AssignSkillsController ..> SkillRepository : skillRepository
AssignSkillsController ..> CollaboratorRepository : collaboratorRepository
SkillRepository "1" --> "*" Skill
CollaboratorRepository "1" --> "*" Collaborator
Repositories --> Repositories : instance
Collaborator "1" --> "1" Skills : skills
Skills "1" --> "*" Skill : skillList

@enduml
