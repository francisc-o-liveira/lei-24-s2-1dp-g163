@startuml
skinparam shadowing false
skinparam classAttributeIconSize 0

left to right direction

package "UI" #f0f0f0 {
    class CollaboratorUI {
        +seeTasks(): void
    }
    class ViewTaskListCollaboratorUI {
        +setTableTasks(tasksInThoseDates: List<EntryDto>): void
    }
}

package "Core" #f0f0f0 {
    
    package "Controller" #dddddd {
        class ViewTaskListAssignedCollabController {
            +getEntriesAssignedToMe(firstDate: Date, secondDate: Date): List<EntryDto>
            +assignEntryCompleted(entryDto: EntryDto, completedDate: Date): void
            +getCollaboratorFromSession(): String
        }
    }

    package "Session" #dddddd {
        class ApplicationSession {
            -instance: ApplicationSession
            +getCurrentSession(): UserSession
        }

        class UserSession {
            +getUserEmail(): String
        }
    }

    package "Mapper" #dddddd {
        class EntryMapper {
            +entryListToEntryDtoList(entryList: List<Entry>): List<EntryDto>
            +toDto(entry: Entry): EntryDto
            +entryDtoToEntry(entryDto: EntryDto, entry: Entry): Entry
            +shouldCompleteTask(entry: Entry, entryDto: EntryDto): boolean
            +completeTask(entry: Entry, entryDto: EntryDto): void
        }
    }

    package "DTO" #dddddd {
        class EntryDto {
            +startDate: Date
            +finishDate: Date
            +status: String
            +collaboratorThatCompleted: Collaborator
            +completeTask(completedDate: Date, collaborator: Collaborator): void
        }
    }

    package "Domain" #dddddd {
        
        package "Repository" #bbbbbb {
            class Repositories {
                -collaboratorRepository: CollaboratorRepository
                -entryRepository: EntryRepository
                -static instance: Repositories
                +getInstance(): Repositories
                +getCollaboratorRepository(): CollaboratorRepository
                +getEntryRepository(): EntryRepository
            }

            class CollaboratorRepository {
                +getCollaboratorByEmail(email: String): Collaborator
            }

            class EntryRepository {
                +getEntriesByCollaboratorInAgenda(collaborator: Collaborator, firstDate: Date, secondDate: Date): List<Entry>
                +completeTaskCollaborator(entryDto: EntryDto): Optional<Entry>
                +searchForEntryAgenda(entryDto: EntryDto): Entry
            }
        }

        package "Model" #bbbbbb {
            class Entry {
                +reference: String
                +status: String
                +startDate: Date
                +finishDate: Date
                +description: String
                +title: String
                +collaboratorThatCompleted: Collaborator
                +completeTask(finishDate: Date, collaborator: Collaborator): void
                +getFinishDate(): Date
                +getCollaboratorFinish(): Collaborator
            }

            class Collaborator {
                +name: String
                +email: String
            }
        }
    }
}

CollaboratorUI ..> ViewTaskListCollaboratorUI
CollaboratorUI ..> ViewTaskListAssignedCollabController
ViewTaskListCollaboratorUI ..> ViewTaskListAssignedCollabController
ViewTaskListAssignedCollabController ..> Repositories : repositories
ViewTaskListAssignedCollabController ..> CollaboratorRepository : collaboratorRepository
ViewTaskListAssignedCollabController ..> EntryRepository : entryRepository
ViewTaskListAssignedCollabController ..> EntryMapper
ViewTaskListAssignedCollabController ..> UserSession
ViewTaskListAssignedCollabController ..> ApplicationSession
ViewTaskListAssignedCollabController ..> EntryDto
EntryMapper ..> EntryDto
EntryMapper ..> Entry
EntryDto ..> Collaborator
Repositories "1" --> "1" CollaboratorRepository
Repositories "1" --> "1" EntryRepository
Repositories --> Repositories : instance
EntryRepository "1" --> "*" Entry
EntryRepository ..> EntryMapper
CollaboratorRepository "1" --> "*" Collaborator
ApplicationSession ..> UserSession

@enduml
