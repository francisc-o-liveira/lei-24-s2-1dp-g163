@startuml
skinparam monochrome true
skinparam packageStyle rectangle
skinparam shadowing false

title System Sequence Diagram (SSD) - Alternative Two

autonumber

actor "GSM" as Manager
participant ":System" as System

activate Manager

    Manager -> System : asks to add a new entry on Agenda
    activate System

        System --> Manager : shows Task list and asks to select one
    deactivate System

    Manager -> System : selects a Task
    activate System

     System --> Manager : shows Team list and asks to select one
        deactivate System

    Manager -> System : selects a Team
        activate System

     System --> Manager : show Vehicle List and ask if want to add
        deactivate System
    opt
       Manager -> System : selects the vehicle's
               activate System
    end
        alt
       System --> System : verify data
        end

        System --> Manager :shows all data and requests confirmation
    deactivate System

    Manager -> System : confirms data
    activate System

        System --> Manager : displays operation success / show list of existing collaborators
    deactivate System
@enduml