@startuml
'skinparam monochrome true
skinparam packageStyle rectangle
skinparam shadowing false
skinparam linetype polyline
'skinparam linetype orto

skinparam classAttributeIconSize 0

'left to right direction

class ApplicationSession{
    + static getInstance()
    + getCurrentSession()
}

class UserSession{
}

class GSM {
}


class Entry {
    - List<Vehicles>
    - Team
    - StartDate
    - Status
    + Entry()
    - setStartDate(startDate)
    + setEntryAgenda(startDate)
}

class Task{
    - GreenSpace
    - Integer timeExpected
}


class EntryRepository {
    - List <Entry> : toDoList
    - List <Entry> : agenda

    + getToDoList()
    + getAgenda()
    + setEntryOnAgenda()
}


class Repositories {
    - Repositories()
    + getInstance() : Repositories
    + getEntryRepository()
}

class AssignEntryOnAgendaController {
    - EntryRepository repository
    + AssignEntryOnAgendaController()
    + getToDoList()
    + assignEntryOnAgenda()
    - getGSMFromSession()
}

note right of AssignEntryOnAgendaController
    - entry is achieved with entry repository
end note

note bottom of EntryRepository
    - used for displaying
    the to do list
end note

class AssignEntryOnAgendaUI {
}

class EntryMapper{
    - List<EntryDto>
    + toModel()
    + toDto()
}

class EntryDto{
    + timeExpected
    - setStartDate(startDate)
    + setEntryAgenda(startDate)
}

class TaskDto{
    -GreenSpace
    -Integer timeExpected
}


Repositories -> Repositories : instance
ApplicationSession -> ApplicationSession : instance

AssignEntryOnAgendaUI .> AssignEntryOnAgendaController

AssignEntryOnAgendaController .> Repositories : repositories
Repositories "1" --> "1" EntryRepository

EntryRepository  ..>  EntryMapper

EntryMapper --> EntryDto

EntryDto - TaskDto : extends


AssignEntryOnAgendaController ..> EntryRepository : EntryRepository
AssignEntryOnAgendaController ..> EntryMapper : EntryMapper

ApplicationSession --> "1" UserSession : userSession
AssignEntryOnAgendaController ..> ApplicationSession
AssignEntryOnAgendaController ..> UserSession
EntryRepository "1" --> "*" Entry : entry's
EntryRepository --> "*" GSM : employs
Entry --> "*" GSM : employs
Task "1" <- "1" Entry : extends


@enduml