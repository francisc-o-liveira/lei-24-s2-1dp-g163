
@startuml
skinparam monochrome true
skinparam packageStyle rectangle
skinparam shadowing false

participant ":TeamMapper" as TeamMapper

participant "teamList:list<Team>" as TeamList
participant "teamListDto:list<TeamDto>" as TeamListDto
participant "objDto:TeamDto" as TeamDto

-> TeamMapper : toDTO(teamList)
autonumber 8.9.1
activate TeamMapper
group Convert Team List to DTO
    
    TeamMapper -> TeamListDto** : create()

    loop for each object in TeamList
        TeamMapper -> TeamList : obj = get()
        activate TeamList
        deactivate TeamList
        TeamMapper -> TeamMapper: objDto = toDto(obj)
        activate TeamMapper

        TeamMapper -> TeamDto** : create(obj.getTeamName())
        deactivate TeamMapper
        TeamMapper -> TeamListDto : add(objDto)
        activate TeamListDto
        deactivate TeamListDto
        end 

        deactivate TeamList

    end

    autonumber 8.10
    <- TeamMapper  : vehicleListDto
    deactivate TeamMapper

    @enduml
