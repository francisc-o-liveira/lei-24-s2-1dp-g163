@startuml
skinparam shadowing false
skinparam classAttributeIconSize 0

left to right direction

package "UI" #f0f0f0{
    class ManageAgendaUI {
    }

    class ViewDetailsEntryUI {
        +setLabels(entryDto: EntryDto): void
    }

    ManageAgendaUI ..> ViewDetailsEntryUI
}
package "Core" #f0f0f0{

    package "Controller" #dddddd{

        class ViewDetailsEntryController {
        }

        ViewDetailsEntryUI ..>  ViewDetailsEntryController


        class AssignEntryOnAgendaController {
            +getAgenda(): List<EntryDto>
        }

        ManageAgendaUI ..> AssignEntryOnAgendaController
    }

    package "Domain" #dddddd{


        package "Mapper" #dddddd{

            class EntryMapper {
                +entryListToEntryDtoList(entryList: List<Entry>): List<EntryDto>
            }

            AssignEntryOnAgendaController ..> EntryMapper

        }

        package "DTO" #dddddd{

            class EntryDto {
                +startDate: Date
                +status: String
                +teamAssigned: TeamDto
                +reference: String
            }

            EntryMapper ..> EntryDto



        }

        package "Repository" #bbbbbb{

            class Repositories {
                - static instance : Repositories
                + getInstance() : Repositories
                + getEntryRepository() : EntryRepository
                - Repositories()
            }

            ViewDetailsEntryController ..> Repositories : repositories
            AssignEntryOnAgendaController ..> Repositories : repositories

            Repositories --> Repositories : instance

            class EntryRepository {
                +getAgenda(): List<Entry>
            }

            Repositories "1" --> "1" EntryRepository : entryRepository
            AssignEntryOnAgendaController ..> EntryRepository : entryRepository


            package "Lists" #999{
                class AgendaList {
                    +getList(): List<Entry>
                }
            }
        }

        package "Model" #bbbbbb{

            class Entry {
                +reference: String
                +status: String
                +startDate: Date
                +teamAssigned: Team
                +finishDate: Date
            }

            EntryRepository "1" --> "*" Entry
            EntryMapper  ..> Entry

        }



    }
}

@enduml
