@startuml
!pragma teoz true
skinparam monochrome true
skinparam packageStyle rectangle
skinparam shadowing false

autonumber

actor "GSM" as Actor

participant ":ViewDetailsEntryAgendaUI" as UI
participant "PostponeUI" as UI2



participant ":ViewDetailsEntryController" as CTRL2
participant "Repositories" as Repos
participant "repositories\n:Repositories" as reposRepos
participant "entryRepository:EntryRepository" as EntryRepo



participant ":EntryMapper" as EntryMapper

participant "entryDto:EntryDto" as EntryDto


participant "entry:Entry" as Entry




activate Actor

ref over Actor : Get details and management options\n of a selected entry on the agenda


Actor -> UI : Asks to postpone an Entry
activate UI


UI -> UI2 :setEntry(entryDto)

activate UI2
deactivate UI

UI2-> Actor : Ask to introduce a new date and a new start hour
deactivate UI2
Actor -> UI2 : Introduces requested data
activate UI2


UI2 -> CTRL2 : postponeEntry(entryDto, postponeDate, startTime)
activate CTRL2
CTRL2-> EntryDto : postpone(newStartDate, newStartTime)
activate EntryDto

deactivate EntryDto









CTRL2 -> EntryRepo : postponeEntry(entryDto)
activate EntryRepo

EntryRepo -> EntryMapper : entryDtoToEntry(entryDto,entry)
activate EntryMapper

EntryMapper -> Entry: postponeEntry(newStartDate)
activate Entry

Entry -> Entry: status.postponeState()
Entry -> Entry: setStartDate(newStartDate)

Entry -> EntryMapper: true


deactivate Entry

EntryMapper -> EntryRepo : true
deactivate EntryMapper

EntryRepo -> CTRL2 :true
deactivate EntryRepo
CTRL2 -> UI2: true


deactivate CTRL2


UI2 -> Actor: Confirms the Change
deactivate UI2
deactivate Actor


@enduml



