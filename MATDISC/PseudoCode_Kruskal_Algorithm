// Função para encontrar o conjunto de um elemento i (usado no algoritmo de Kruskal)
function encontrar(conjunto, i):
    if conjunto[i] != i:
        conjunto[i] = encontrar(conjunto, conjunto[i])
    return conjunto[i]

// Função para unir dois subconjuntos (usado no algoritmo de Kruskal)
function unir(conjunto, rank, x, y):
    raizX = encontrar(conjunto, x)
    raizY = encontrar(conjunto, y)
    if raizX != raizY:
        if rank[raizX] > rank[raizY]:
            conjunto[raizY] = raizX
        else if rank[raizX] < rank[raizY]:
            conjunto[raizX] = raizY
        else:
            conjunto[raizY] = raizX
            rank[raizX] += 1

// Algoritmo de Kruskal para encontrar a árvore geradora mínima
function algoritmoDeKruskal(arestas):
    resultado = lista vazia
    vertices = obterVertices(arestas)
    V = tamanho(vertices)
    conjunto = novo array de tamanho V
    rank = novo array de tamanho V
    para i de 0 até V-1:
        conjunto[i] = i
        rank[i] = 0
    para cada aresta in arestas:
        x = encontrarIndiceDoVertice(aresta.getP1(), vertices)
        y = encontrarIndiceDoVertice(aresta.getP2(), vertices)
        raizX = encontrar(conjunto, x)
        raizY = encontrar(conjunto, y)
        if raizX != raizY:
            adicionar aresta a resultado
            unir(conjunto, rank, raizX, raizY)
    return resultado

