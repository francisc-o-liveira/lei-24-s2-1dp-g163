function numberOfVertices(edges):
    vertices = empty list
    for each edge in edges:
        value1 = false
        value2 = false
        x1 = edge.getP1()
        x2 = edge.getP2()
        for each point in vertices:
            if x1 == point:
                value1 = true
            if x2 == point:
                value2 = true
        if not value1:
            append x1 to vertices
        if not value2:
            append x2 to vertices
    return vertices

function readFromFile(fileName):
    scanFile = open file fileName
    edges = empty list
    while scanFile has next line:
        line = split(scanFile next line, ";")
        append new Edge(new Point(line[0]), new Point(line[1]), toInt(line[2])) to edges
    return edges

