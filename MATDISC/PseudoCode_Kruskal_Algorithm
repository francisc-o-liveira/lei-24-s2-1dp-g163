function readFromFile(fileName):
    scanFile = open file fileName
    edges = empty list
    while scanFile has next line:
        line = split(scanFile next line, ";")
        append new Edge(new Point(line[0]), new Point(line[1]), toInt(line[2])) to edges
    return edges

