// Function to find the index of the vertex with the minimum cost that has not been visited yet
function indexOfMin(costsOfVertices, verticesVisited, numVertices):
    min = INFINITY
    indexOfMinimum = -1
    for j = 0 to numVertices-1:
        if not verticesVisited[j] and costsOfVertices[j] < min:
            min = costsOfVertices[j]
            indexOfMinimum = j
    return indexOfMinimum

// Dijkstra's Algorithm to find the shortest path from startingPoint to all vertices
function dijkstraAlgorithmUS18(edges, startingPoint, vertices):
    resultPath = empty list of Edge

    numVertices = size of vertices

    // Initialize the cost list with INFINITY
    costsOfVertices = list of size numVertices with all elements set to INFINITY
    // Initialize the visited list with false
    verticesUsed = list of size numVertices with all elements set to false
    // Initialize the path list with null
    pathVertices = list of size numVertices with all elements set to null

    indexOfStartingPoint = index of startingPoint in vertices

    // Set the cost of the starting point to 0
    costsOfVertices[indexOfStartingPoint] = 0

    // Loop to process each vertex
    for i = 0 to numVertices-2:
        // Find the index of the vertex with the minimum cost
        indexOfMinimum = indexOfMin(costsOfVertices, verticesUsed, numVertices)
        // Stop if all vertices have been processed
        if indexOfMinimum == -1:
            break

        chosenVertex = vertices[indexOfMinimum]
        verticesUsed[indexOfMinimum] = true

        // Update the costs for adjacent vertices
        for edge in edges:
            if edge.p1 equals chosenVertex:
                indexOfNext = index of edge.p2 in vertices
                if not verticesUsed[indexOfNext]:
                    cost = costsOfVertices[indexOfMinimum] + edge.price
                    if cost < costsOfVertices[indexOfNext]:
                        costsOfVertices[indexOfNext] = cost
                        pathVertices[indexOfNext] = chosenVertex

    // Build the result path
    for i = 0 to numVertices-1:
        if pathVertices[i] is not null:
            resultPath.add(new Edge(pathVertices[i], vertices[i], costsOfVertices[i]))

    return resultPath
