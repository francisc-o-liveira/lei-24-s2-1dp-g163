    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "# Load data from the CSV file (replace 'EquipmentUsed.csv' with the actual file path)\n",
    "csv_file_path = 'EquipmentUsed.csv'\n",
    "df = pd.read_csv(csv_file_path)\n",
    "\n",
    "# Assuming the column names are 'WalkingPaths', 'Playground', 'PicnicArea', and 'ExerciseMachines'\n",
    "# Count the number of users who used each equipment\n",
    "equipment_counts = df[['WalkingPaths', 'Playground', 'PicnicArea', 'ExerciseMachines']].sum()\n",
    "\n",
    "# Calculate percentages\n",
    "total_users = len(df)\n",
    "percentages = (equipment_counts / total_users) * 100\n",
    "\n",
    "# Create a pie chart\n",
    "labels = ['Walking Paths', \"Children's Playground\", 'Picnic Area', 'Exercise Machines']\n",
    "colors = ['#FF9999', '#66B3FF', '#99FF99', '#FFCC99']\n",
    "plt.pie(percentages, labels=labels, colors=colors, autopct='%1.1f%%', startangle=90)\n",
    "plt.title('Equipment Usage in the Park')\n",
    "\n",
    "# Show the pie chart\n",
    "plt.axis('equal')  # Equal aspect ratio ensures that pie is drawn as a circle.\n",
    "plt.show()"
   ],
